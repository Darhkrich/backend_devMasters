APP_ENV=development
DEBUG=True
SECRET_KEY=replace-with-strong-secret
AUDIT_LOG_SIGNING_KEY=replace-with-separate-audit-signing-key

ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=False
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_PATH=/
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_DOMAIN=
CSRF_COOKIE_PATH=/
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=False

DATABASE_URL=postgresql://postgres:replace-with-db-password@localhost:5432/backend_db
REDIS_URL=

DB_NAME=backend_db
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=replace@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password
EMAIL_SUBJECT_PREFIX=[Enterprise Admin] 
DEFAULT_FROM_EMAIL=no-reply@example.com

AUDIT_LOG_RETENTION_DAYS=365
SECURITY_EVENT_RETENTION_DAYS=180
LOGIN_HISTORY_RETENTION_DAYS=180
DEVICE_SESSION_RETENTION_DAYS=90
DEVICE_TRUST_DAYS=30
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SENSITIVE_ADMIN_PATH_PREFIXES=/admin,/api/v1/security,/api/v1/audit

